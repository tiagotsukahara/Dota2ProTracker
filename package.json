{
  "name": "dota2protracker-meta-grid",
  "version": "0.1.0",
  "description": "Windows app to download Dota2ProTracker meta hero grids into Dota 2.",
  "main": "dist/main/main.js",
  "author": "Teis Lab",
  "license": "MIT",
  "scripts": {
    "dev": "npm.cmd run build:main && vite --host 127.0.0.1",
    "start": "npm.cmd run build && electron .",
    "build": "npm.cmd run typecheck && npm.cmd run build:main && npm.cmd run build:renderer",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm.cmd run build:main && node --test tests/*.test.mjs",
    "pack": "npm.cmd run build && electron-builder --win portable",
    "dist": "npm.cmd run build && electron-builder --win nsis portable"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
